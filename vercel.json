{
  "$schema": "https://openapi.vercel.sh/vercel.json",
  "buildCommand": "cd web && npm install && npm run build",
  "outputDirectory": "web/dist",
  "functions": {
    "api/explain.py":  { "includeFiles": "timetabler/**" },
    "api/generate.py": { "includeFiles": "timetabler/**" },
    "api/place.py":    { "includeFiles": "timetabler/**" },
    "api/simulate.py": { "includeFiles": "timetabler/**" },
    "api/suggest.py":  { "includeFiles": "timetabler/**" },
    "api/validate.py": { "includeFiles": "timetabler/**" }
  },
  "rewrites": [
    { "source": "/api/(.*)", "destination": "/api/$1" },
    { "source": "/(.*)",     "destination": "/index.html" }
  ],
  "headers": [
    {
      "source": "/(.*)",
      "headers": [
        { "key": "X-Content-Type-Options",  "value": "nosniff" },
        { "key": "X-Frame-Options",          "value": "DENY" },
        { "key": "Referrer-Policy",          "value": "strict-origin-when-cross-origin" },
        { "key": "Permissions-Policy",       "value": "camera=(), microphone=(), geolocation=()" }
      ]
    }
  ]
}
