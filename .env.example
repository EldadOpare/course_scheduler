# Ashesi Timetabler — environment variables
# Copy to .env for local development. On Vercel, set these under
# Project Settings → Environment Variables (never commit .env).

# ── Python engine ────────────────────────────────────────────────────────────

# Optional: enables the "Ask Grok" plain-English summaries (x.ai API key).
# The engine and UI work fully without it.
XAI_API_KEY=

# Optional: which Grok model to use for summaries.
XAI_MODEL=grok-2-1212

# ── React frontend (prefix VITE_ required) ────────────────────────────────────

# Supabase project URL — find in your Supabase dashboard → Project Settings → API.
VITE_SUPABASE_URL=https://your-project.supabase.co

# Supabase anon / public key (safe to commit but don't expose service_role key).
VITE_SUPABASE_ANON_KEY=your-anon-key

# ── Supabase schema ───────────────────────────────────────────────────────────
#
# Run supabase/migrations/001_initial_schema.sql once in the Supabase SQL Editor.
# It creates: courses, faculty, rooms, year_groups, majors, academic_semesters,
# course_plans, settings, timetable_sessions, placements
# and enables RLS + realtime on placements.
